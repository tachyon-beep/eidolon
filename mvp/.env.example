# Database
DATABASE_URL=postgresql://localhost/eidolon_mvp

# LLM Provider: "anthropic", "openai", or "openai-compatible"
LLM_PROVIDER=anthropic

# Anthropic (direct)
ANTHROPIC_API_KEY=your_key_here

# OpenAI (direct)
# OPENAI_API_KEY=your_key_here

# OpenAI-compatible (e.g., OpenRouter)
# LLM_PROVIDER=openai-compatible
# OPENAI_API_KEY=your_openrouter_key_here
# OPENAI_BASE_URL=https://openrouter.ai/api/v1
# LLM_MODEL=anthropic/claude-3.5-sonnet

# Optional: Model selection (overrides defaults)
# ANTHROPIC_MODEL=claude-3-5-sonnet-20241022
# OPENAI_MODEL=gpt-4-turbo-preview
# LLM_MODEL=anthropic/claude-3.5-sonnet  # For OpenRouter
